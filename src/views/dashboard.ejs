<%- include('partials/header') %>

<main class="content-wrapper">
    <h1><%= title %></h1>

    <div class="user-info">
        <h2>Welcome, <%= name %>!</h2>
        <p>Email: <%= email %></p>
    </div>

    <!-- Volunteer Projects Section -->
    <div class="volunteer-projects" style="margin-top: 2rem;">
        <h3>My Volunteer Projects</h3>
        
        <% if (volunteerProjects && volunteerProjects.length > 0) { %>
            <table class="volunteer-table" style="width: 100%; border-collapse: collapse; margin-top: 1rem;">
                <thead>
                    <tr style="background-color: #f4f4f4; text-align: left;">
                        <th style="padding: 10px; border-bottom: 2px solid #ddd;">Project Title</th>
                        <th style="padding: 10px; border-bottom: 2px solid #ddd;">Organization</th>
                        <th style="padding: 10px; border-bottom: 2px solid #ddd;">Date</th>
                        <th style="padding: 10px; border-bottom: 2px solid #ddd;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% volunteerProjects.forEach(project => { %>
                        <tr>
                            <td style="padding: 10px; border-bottom: 1px solid #eee;">
                                <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                            </td>
                            <td style="padding: 10px; border-bottom: 1px solid #eee;"><%= project.organization_name %></td>
                            <td style="padding: 10px; border-bottom: 1px solid #eee;"><%= project.project_date %></td>
                            <td style="padding: 10px; border-bottom: 1px solid #eee;">
                                <form action="/unvolunteer/<%= project.project_id %>" method="POST" style="display:inline;">
                                    <button type="submit" class="btn btn-small" style="background-color: #dc3545; color: white; border: none; padding: 5px 10px; cursor: pointer; border-radius: 4px;">Remove</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <p>You are not currently volunteering for any projects.</p>
            <p><a href="/projects">Browse upcoming projects</a> to find one to join!</p>
        <% } %>
    </div>

</main>

<%- include('partials/footer') %>