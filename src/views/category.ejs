<%- include('partials/header') %>
<main class="content-wrapper">
    <h1><%= title %></h1>

    <h2><%= category.name %></h2>
    
    <% if (user && user.role_name === 'admin') { %>
        <p>
            <a href="/edit-category/<%= category.category_id %>">Edit Category</a> | 
            <a href="/new-category">Add New Category</a>
        </p>
    <% } %>

    <h3>Service Projects in this Category</h3>
    <% if (projects && projects.length > 0) { %>
        <ul class="project-list">
            <% projects.forEach(project => { %>
                <li>
                    <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                    - <%= project.location %>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No projects currently listed in this category.</p>
    <% } %>
</main>
<%- include('partials/footer') %>