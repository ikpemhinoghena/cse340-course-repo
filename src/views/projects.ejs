<%- include('partials/header') %>
<main class="content-wrapper">
    <h1><%= title %></h1>
    
    <p>Join us in making a difference through these upcoming projects:</p>
    
    <div class="project-list">
        <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <div class="project-card">
                    <h2>
                        <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                    </h2>
                    <p><strong>Date:</strong> <%= project.date %></p>
                    <p><strong>Location:</strong> <%= project.location %></p>
                    <p>
                        <strong>Organization:</strong> 
                        <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
                    </p>
                </div>
            <% }) %>
        <% } else { %>
            <p>No upcoming projects at this time.</p>
        <% } %>
    </div>

    <% if (user && user.role_name === 'admin') { %>
        <p><a href="/new-project">Add a New Service Project</a></p>
    <% } %>
</main>
<%- include('partials/footer') %>