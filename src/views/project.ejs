<%- include('partials/header') %>
<main class="content-wrapper">
    <h1><%= title %></h1>

    <h2><%= project.title %></h2>
    
    <p><strong>Date:</strong> <%= project.date %></p>
    <p><strong>Location:</strong> <%= project.location %></p>
    
    <p><%= project.description %></p>

    <p>
        <strong>Partner Organization:</strong> 
        <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
    </p>

    <% if (user && user.role_name === 'admin') { %>
        <p><a href="/edit-project/<%= project.project_id %>">Edit Project</a></p>
        <p><a href="/assign-categories/<%= project.project_id %>">Edit Categories</a></p>
    <% } %>

    <% if (categories && categories.length > 0) { %>
        <div class="category-tags">
            <strong>Categories:</strong>
            <% categories.forEach(cat => { %>
                <a href="/category/<%= cat.category_id %>" class="tag"><%= cat.name %></a>
            <% }) %>
        </div>
    <% } %>

    <!-- Volunteer Section -->
    <div class="volunteer-section" style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #eee;">
        <% if (isLoggedIn) { %>
            <% if (isVolunteering) { %>
                <p class="success-message" style="color: green; font-weight: bold;">You are currently volunteering for this project!</p>
                <form action="/unvolunteer/<%= project.project_id %>" method="POST">
                    <button type="submit" class="btn btn-secondary">Remove Me as Volunteer</button>
                </form>
            <% } else { %>
                <form action="/volunteer/<%= project.project_id %>" method="POST">
                    <button type="submit" class="btn btn-primary">Volunteer for this Project</button>
                </form>
            <% } %>
        <% } else { %>
            <p><a href="/login">Log in</a> to volunteer for this project.</p>
        <% } %>
    </div>
</main>
<%- include('partials/footer') %>